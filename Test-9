function saveTicket(){
  const empId=parseInt(document.getElementById('tk-emp').value);
  const title=document.getElementById('tk-title').value.trim();
  const pts=parseInt(document.getElementById('tk-diff').value);
  const status=document.getElementById('tk-status').value;
  const time=parseInt(document.getElementById('tk-time').value)||0;
  const editId=document.getElementById('tk-edit-id').value;
  if(!title)return;
  const emp=employees.find(e=>e.id===empId);if(!emp)return;
  let sp=0;if(time>0&&time<5)sp=15;else if(time<15)sp=10;else if(time<30)sp=5;
  if(editId){
    const tk=tickets.find(t=>t.id===editId);
    if(tk){
      if(tk.status==='closed'){const oe=employees.find(e=>e.id===tk.empId);if(oe)oe.points=Math.max(0,oe.points-tk.pts)}
      tk.empId=empId;tk.title=title;tk.pts=pts;tk.status=status;tk.time=time?time+' دق':'غير محدد';
      if(status==='closed'){emp.points+=pts+sp;emp.tickets++}
    }
    showNotif('✅ تم تعديل التكت');
  } else {
    const tkId='TK-'+(1042+tickets.length+1);
    tickets.unshift({id:tkId,title,empId,status,pts,time:time?time+' دق':'غير محدد'});
    if(status==='closed'){emp.points+=pts+sp;emp.tickets++;history.unshift({id:histId++,emp:emp.name,action:`${tkId} مغلق`,pts:pts+sp,type:'green',time:'الآن'})}
    showNotif(`🎫 تم تسجيل ${tkId}`);
  }
  closeModal('addTicket');
  (async function(){ const te=document.getElementById('tk-edit-id').value; await dbSaveTicket(te?tickets.find(function(t){return t.id===te;}):tickets[0]); renderAll(); })();
}
