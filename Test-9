const RM_PASS = 'Make_by_omar';
let selectedRole = null;

function selectRole(role){
  selectedRole = role;
  document.querySelectorAll('.role-btn').forEach(function(b){ b.classList.remove('selected'); });
  document.querySelectorAll('.role-check').forEach(function(c){ c.textContent=''; });
  if(role==='staff'){
    document.getElementById('roleStaff').classList.add('selected');
    document.getElementById('checkStaff').textContent='✓';
    document.getElementById('passwordField').style.display='none';
  } else {
    document.getElementById('roleRM').classList.add('selected');
    document.getElementById('checkRM').textContent='✓';
    document.getElementById('passwordField').style.display='block';
    document.getElementById('loginPass').focus();
  }
  document.getElementById('loginErr').style.display='none';
}

function doLogin(){
  if(!selectedRole){ return; }
  if(selectedRole==='rank_manager'){
    const pass = document.getElementById('loginPass').value;
    if(pass !== RM_PASS){
      document.getElementById('loginErr').style.display='block';
      return;
    }
    currentUser = { name: 'Rank Manager', role: 'admin' };
    document.body.classList.add('is-admin');
    document.getElementById('criteriaLock').style.display='none';
    document.getElementById('ranksLock').style.display='none';
  } else {
    currentUser = { name: 'Staff', role: 'staff' };
    document.body.classList.add('is-staff');
  }
  document.getElementById('loginScreen').style.display='none';
  document.getElementById('mainApp').style.display='block';
  setTimeout(function(){
    showTab('dashboard', document.querySelector('[onclick*="dashboard"]'));
    setDashView('table');
    loadFromDB();
  }, 50);
}

