function saveEmployee(){
  const name=document.getElementById('emp-name').value.trim();
  const role=document.getElementById('emp-role').value.trim();
  const avatar=document.getElementById('emp-avatar').value.trim();
  const color=document.getElementById('emp-color').value;
  const editId=document.getElementById('emp-edit-id').value;
  const rankSel=document.getElementById('emp-rank-select');
  const rankIdx=rankSel&&rankSel.value!==''?parseInt(rankSel.value):-1;
  if(!name) return;
  const chosenRank=rankIdx>=0?RANKS[rankIdx]:null;
  const startPts=chosenRank?chosenRank.min:0;
  if(editId){
    const emp=employees.find(function(e){ return e.id===parseInt(editId); });
    if(emp){
      emp.name=name; emp.role=role||emp.role; emp.avatar=avatar||emp.avatar; emp.color=color;
      if(chosenRank) emp.points=startPts;
    }
    closeModal('addEmp');
    (async function(){ await dbSaveEmp(employees.find(function(e){ return e.id===parseInt(editId); })); renderAll(); })();
    showNotif('✅ تم تعديل بيانات الموظف');
  } else {
    const newEmp={id:Date.now(),name:name,role:role||'موظف',avatar:avatar||name[0],color:color,points:startPts,tickets:0};
    employees.push(newEmp);
    if(chosenRank){
      history.unshift({id:histId++,emp:name,action:'رتبة ابتدائية: '+chosenRank.emoji+' '+chosenRank.name,pts:startPts,type:'gold',time:'الآن'});
    }
    closeModal('addEmp');
    (async function(){ await dbSaveEmp(newEmp); if(chosenRank) await dbAddHist(history[0]); renderAll(); })();
    showNotif('✅ تم إضافة '+name+(chosenRank?' برتبة '+chosenRank.emoji+' '+chosenRank.name:''));
  }
}

