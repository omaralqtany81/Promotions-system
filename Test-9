async function sbFetch(path, method, body){
  method = method || 'GET';
  const opts = {
    method: method,
    headers: {
      'apikey': SB_KEY,
      'Authorization': 'Bearer ' + SB_KEY,
      'Content-Type': 'application/json',
      'Prefer': (method==='POST' ? 'return=representation' : 'return=minimal')
    }
  };
  if(body) opts.body = JSON.stringify(body);
  const res = await fetch(SB_URL + '/rest/v1/' + path, opts);
  if(res.status===204) return true;
  const text = await res.text();
  return text ? JSON.parse(text) : true;
}

async function loadFromDB(){
  showLoading(true);
  try {
    const [emps,tkts,hist,rnks,crit] = await Promise.all([
      sbFetch('employees?order=points.desc'),
      sbFetch('tickets?order=created_at.desc'),
      sbFetch('history?order=created_at.desc&limit=100'),
      sbFetch('ranks?order=min_pts.asc'),
      sbFetch('criteria?order=id.asc'),
    ]);
    if(Array.isArray(emps) && emps.length)
      employees = emps.map(function(r){ return {id:r.id,name:r.name,role:r.role,avatar:r.avatar,color:r.color,points:r.points,tickets:r.tickets}; });
    if(Array.isArray(tkts) && tkts.length)
      tickets = tkts.map(function(r){ return {id:r.ticket_id,title:r.title,empId:r.emp_id,status:r.status,pts:r.pts,time:r.response_time}; });
    if(Array.isArray(hist) && hist.length)
      history = hist.map(function(r){ return {id:r.id,emp:r.emp_name,action:r.action,pts:r.pts,type:r.dot_type,time:r.time_label}; });
    if(Array.isArray(rnks) && rnks.length)
      RANKS = rnks.map(function(r){ return {name:r.name,emoji:r.emoji,min:r.min_pts,max:r.max_pts,color:r.color,perks:r.perks,class:r.badge_class}; });
    if(Array.isArray(crit) && crit.length)
      CRITERIA = crit.map(function(r){ return {name:r.name,icon:r.icon,desc:r.descr,items:JSON.parse(r.items_json)}; });
  } catch(e){ console.error('DB load error',e); }
  showLoading(false);
  renderAll();
}

async function dbSaveEmp(emp){
  if(!emp) return;
  const row = {id:emp.id,name:emp.name,role:emp.role,avatar:emp.avatar,color:emp.color,points:emp.points,tickets:emp.tickets};
  const chk = await sbFetch('employees?id=eq.'+emp.id);
  if(Array.isArray(chk) && chk.length) await sbFetch('employees?id=eq.'+emp.id,'PATCH',row);
  else await sbFetch('employees','POST',row);
}
async function dbDeleteEmp(id){ await sbFetch('employees?id=eq.'+id,'DELETE'); }

async function dbSaveTicket(t){
  if(!t) return;
  const row = {ticket_id:t.id,title:t.title,emp_id:t.empId,status:t.status,pts:t.pts,response_time:t.time};
  const chk = await sbFetch('tickets?ticket_id=eq.'+encodeURIComponent(t.id));
  if(Array.isArray(chk) && chk.length) await sbFetch('tickets?ticket_id=eq.'+encodeURIComponent(t.id),'PATCH',row);
  else await sbFetch('tickets','POST',row);
}
async function dbDeleteTicket(tkId){ await sbFetch('tickets?ticket_id=eq.'+encodeURIComponent(tkId),'DELETE'); }

async function dbAddHist(h){
  if(!h) return;
  const row = {emp_name:h.emp,action:h.action,pts:h.pts,dot_type:h.type,time_label:h.time};
  const res = await sbFetch('history','POST',row);
  if(Array.isArray(res) && res[0] && res[0].id) h.id = res[0].id;
}
async function dbPatchHist(h){
  if(!h||!h.id) return;
  await sbFetch('history?id=eq.'+h.id,'PATCH',{emp_name:h.emp,action:h.action,pts:h.pts,dot_type:h.type,time_label:h.time});
}
async function dbDeleteHist(id){ await sbFetch('history?id=eq.'+id,'DELETE'); }

async function dbSaveAllRanks(){
  await sbFetch('ranks?id=gte.0','DELETE');
  for(const r of RANKS){
    await sbFetch('ranks','POST',{name:r.name,emoji:r.emoji,min_pts:r.min,max_pts:r.max,color:r.color,perks:r.perks,badge_class:r.class});
  }
}

async function dbSaveAllCriteria(){
  await sbFetch('criteria?id=gte.0','DELETE');
  for(const c of CRITERIA){
    await sbFetch('criteria','POST',{name:c.name,icon:c.icon,descr:c.desc,items_json:JSON.stringify(c.items)});
  }
}

function showLoading(show){
  let el=document.getElementById('loadingOverlay');
  if(!el){
    el=document.createElement('div');
    el.id='loadingOverlay';
    el.style.cssText='position:fixed;inset:0;background:rgba(13,13,13,0.9);z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;backdrop-filter:blur(6px)';
    el.innerHTML='<div style="font-size:40px" id="loadSpin">⚙️</div><div style="font-size:14px;color:#F4B942;font-weight:700;font-family:Tajawal,sans-serif">جاري التحميل...</div>';
    const s=document.createElement('style');
    s.textContent='@keyframes spin2{from{transform:rotate(0)}to{transform:rotate(360deg)}} #loadSpin{animation:spin2 1s linear infinite}';
    document.head.appendChild(s);
    document.body.appendChild(el);
  }
  el.style.display=show?'flex':'none';
}

