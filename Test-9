function renderCharts(){
  const emps = sortedEmps().slice(0,10);
  const names = emps.map(function(e){ return e.name.split(' ')[0]; });
  const colors = emps.map(function(e){ return e.color; });
  const chartOpts = {
    responsive:true, maintainAspectRatio:false,
    plugins:{legend:{display:false}},
    scales:{
      x:{ticks:{color:'#888',font:{family:'Tajawal',size:10}},grid:{color:'rgba(255,255,255,0.04)'}},
      y:{ticks:{color:'#888',font:{family:'Tajawal',size:10}},grid:{color:'rgba(255,255,255,0.04)'}}
    }
  };

  // Points chart
  if(chartPointsInst) chartPointsInst.destroy();
  const ctx1 = document.getElementById('chartPoints');
  if(ctx1) chartPointsInst = new Chart(ctx1, {
    type:'bar',
    data:{
      labels:names,
      datasets:[{data:emps.map(function(e){return e.points;}),backgroundColor:colors.map(function(c){return c+'99';}),borderColor:colors,borderWidth:2,borderRadius:6}]
    },
    options: chartOpts
  });

  // Tickets chart
  if(chartTicketsInst) chartTicketsInst.destroy();
  const ctx2 = document.getElementById('chartTickets');
  if(ctx2) chartTicketsInst = new Chart(ctx2, {
    type:'bar',
    data:{
      labels:names,
      datasets:[{data:emps.map(function(e){return e.tickets;}),backgroundColor:'rgba(92,158,255,0.5)',borderColor:'#5C9EFF',borderWidth:2,borderRadius:6}]
    },
    options: chartOpts
  });

  // Ranks pie chart
  if(chartRanksInst) chartRanksInst.destroy();
  const rankCounts = {};
  employees.forEach(function(e){
    const rn = getRank(e.points).name;
    rankCounts[rn] = (rankCounts[rn]||0)+1;
  });
  const rLabels = Object.keys(rankCounts);
  const rData = rLabels.map(function(k){return rankCounts[k];});
  const rColors = rLabels.map(function(k){ const r=RANKS.find(function(r){return r.name===k;}); return r?r.color:'#888'; });
  const ctx3 = document.getElementById('chartRanks');
  if(ctx3) chartRanksInst = new Chart(ctx3, {
    type:'doughnut',
    data:{labels:rLabels,datasets:[{data:rData,backgroundColor:rColors.map(function(c){return c+'bb';}),borderColor:rColors,borderWidth:2}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#ccc',font:{family:'Tajawal',size:12}}}}}
  });
}

