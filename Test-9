<script>
// ==================== STATE ====================
let currentUser = null;
let selectedPts = 10;
let pendingDeleteFn = null;
let loginRole = 'admin';
let histId = 100;

let RANKS = [];
let CRITERIA = [];
let employees = [];
let tickets = [];
let history = [];

// ==================== HELPERS ====================
function getRank(pts){for(let i=RANKS.length-1;i>=0;i--)if(pts>=RANKS[i].min)return RANKS[i];return RANKS[0]}
function getNextRank(pts){for(let i=0;i<RANKS.length;i++)if(pts<RANKS[i].max)return RANKS[i];return RANKS[RANKS.length-1]}
function getRankProg(pts){const r=getRank(pts);return Math.min(100,Math.round(((pts-r.min)/(r.max-r.min))*100))}
function sortedEmps(){return[...employees].sort((a,b)=>b.points-a.points)}
function empName(id){const e=employees.find(e=>e.id===id);return e?e.name:'غير معروف'}
const isAdmin=()=>currentUser&&currentUser.role==='admin'

// ==================== RENDER ====================
function renderAll(){
  renderDash(); renderFullTable(); renderTickets();
  renderCriteria(); renderRanks(); renderHistory();
  updateStats(); populateSelects();
}

function empRowHTML(emp){
  const rank=getRank(emp.points);
  const prog=getRankProg(emp.points);
  const adm=isAdmin();
  return`<div class="emp-row" onclick="showEmpDetail(${emp.id})">
    <div><div class="emp-avatar" style="background:linear-gradient(135deg,${emp.color},${emp.color}88)">${emp.avatar}</div></div>
    <div><div class="emp-name">${emp.name}</div><div class="emp-role">${emp.role}</div></div>
    <div><span class="rank-badge ${rank.class}">${rank.emoji} ${rank.name}</span></div>
    <div class="pts-bar"><div class="pts-val">${emp.points.toLocaleString()}</div><div class="progress-bar"><div class="progress-fill" style="width:${prog}%"></div></div></div>
    <div style="font-size:12px;font-weight:700;color:var(--blue)">${emp.tickets}</div>
    <div class="row-acts" onclick="event.stopPropagation()">
      ${adm?`<button class="icon-btn pts" title="نقاط" onclick="openPtsFor(${emp.id})">⭐</button>
             <button class="icon-btn edit" title="تعديل" onclick="openEditEmp(${emp.id})">✏️</button>
             <button class="icon-btn del" title="حذف" onclick="askDel('حذف الموظف ${emp.name}؟',()=>deleteEmp(${emp.id}))">🗑️</button>`
             :'<span style="font-size:11px;color:var(--text-muted)">عرض فقط</span>'}
    </div>
  </div>`;
}

function renderDash(){
  document.getElementById('dashEmpTable').innerHTML=sortedEmps().map(e=>empRowHTML(e)).join('');
  const s=sortedEmps().slice(0,5);
  const rc=['r1','r2','r3','rn','rn'];
  document.getElementById('leaderboard').innerHTML=s.map((e,i)=>`
    <div class="lb-item ${i===0?'first':''}" onclick="showEmpDetail(${e.id})">
      <div class="lb-rank ${rc[i]}">${i+1}</div>
      <div class="lb-av" style="background:linear-gradient(135deg,${e.color},${e.color}88)">${e.avatar}</div>
      <div class="lb-info"><div class="lb-nm">${e.name}</div><div class="lb-sub">${e.tickets} تكت</div></div>
      <div class="lb-sc">${e.points.toLocaleString()}</div>
    </div>`).join('');
  const all=sortedEmps();
  const mx=all[0]?.points||1;
  document.getElementById('distribChart').innerHTML=all.map(e=>`
    <div style="display:flex;align-items:center;gap:7px;margin-bottom:8px">
      <div style="width:22px;height:22px;border-radius:6px;background:linear-gradient(135deg,${e.color},${e.color}88);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:var(--dark);flex-shrink:0">${e.avatar}</div>
      <div style="flex:1"><div style="font-size:10px;color:var(--text-muted);margin-bottom:2px">${e.name}</div><div style="height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden"><div style="height:100%;width:${Math.round((e.points/mx)*100)}%;background:linear-gradient(90deg,${e.color}88,${e.color});border-radius:2px"></div></div></div>
      <div style="font-size:10px;font-weight:700;color:${e.color};min-width:46px;text-align:left">${e.points.toLocaleString()}</div>
    </div>`).join('');
}

function renderFullTable(){document.getElementById('fullEmpTable').innerHTML=sortedEmps().map(e=>empRowHTML(e)).join('')}

function renderTickets(){
  const adm=isAdmin();
  document.getElementById('ticketsGrid').innerHTML=tickets.map(t=>{
    const sc={closed:'status-closed',open:'status-open',pending:'status-pending'}[t.status];
    const sl={closed:'مغلق',open:'مفتوح',pending:'معلق'}[t.status];
    return`<div class="ticket-card">
      ${adm?`<div class="ticket-actions-overlay">
        <button class="icon-btn edit" onclick="openEditTicket('${t.id}')">✏️</button>
        <button class="icon-btn del" onclick="askDel('حذف التكت ${t.id}؟',()=>deleteTicket('${t.id}'))">🗑️</button>
      </div>`:''}
      <div class="ticket-id">${t.id}</div>
      <div class="ticket-title">${t.title}</div>
      <div class="ticket-meta">
        <span class="ticket-status ${sc}">${sl}</span>
        <span class="ticket-pts">⭐ +${t.pts}</span>
        <span class="ticket-assign">👤 ${empName(t.empId)}</span>
        <span class="ticket-assign">⚡ ${t.time}</span>
      </div>
    </div>`;
  }).join('');
}

function renderCriteria(){
  const adm=isAdmin();
  document.getElementById('criteriaGrid').innerHTML=CRITERIA.map((c,i)=>`
    <div class="criteria-card">
      ${adm?`<div class="cr-actions">
        <button class="icon-btn edit" onclick="openEditCriteria(${i})" title="تعديل">✏️</button>
        <button class="icon-btn del" onclick="askDel('حذف معيار ${c.name}؟',()=>deleteCriteria(${i}))">🗑️</button>
      </div>`:''}
      <div class="criteria-icon-big">${c.icon}</div>
      <div class="criteria-name">${c.name}</div>
      <div class="criteria-desc">${c.desc}</div>
      <div class="cp-list">${c.items.map(it=>`
        <div class="cp-row"><span>${it.l}</span><span class="cp-pts ${it.p<0?'neg':''}">${it.p>0?'+':''}${it.p} نقطة</span></div>
      `).join('')}</div>
    </div>`).join('');
}

function renderRanks(){
  const adm=isAdmin();
  document.getElementById('ranksList').innerHTML=[...RANKS].reverse().map((r,ri)=>{
    const realIdx=RANKS.length-1-ri;
    const cnt=employees.filter(e=>getRank(e.points).name===r.name).length;
    return`<div class="rank-row-item">
      <div class="rank-emoji-big">${r.emoji}</div>
      <div class="rank-info-block">
        <div class="rank-nm" style="color:${r.color}">${r.name} <span class="rank-badge ${r.class}" style="margin-right:5px">${r.min.toLocaleString()}+ نقطة</span></div>
