<!DOCTYPE html>

<html lang="ar" dir="rtl"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<title>نظام الترقيات - لوحة الإدارة</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --gold:#F4B942;--gold-light:#FFD97D;--gold-dark:#C9922A;
    --dark:#0D0D0D;--dark2:#141414;--dark3:#1C1C1C;--dark4:#242424;--dark5:#2E2E2E;
    --text:#F0F0F0;--text-muted:#888;
    --green:#3ECF8E;--red:#FF5C5C;--blue:#5C9EFF;--purple:#A78BFA;
    --border:rgba(244,185,66,0.15);
  }
  /* LIGHT MODE */
  body.light-mode {
    --dark:#EDEAE4;--dark2:#F5F2ED;--dark3:#EBE7E0;--dark4:#E2DDD6;--dark5:#D8D2CA;
    --text:#2A2520;--text-muted:#7A7570;
    --border:rgba(180,140,60,0.2);
  }
  body.light-mode header{box-shadow:0 2px 12px rgba(0,0,0,0.08)}
  body.light-mode .card{box-shadow:0 2px 12px rgba(0,0,0,0.06)}
  body.light-mode .stat-card{box-shadow:0 2px 12px rgba(0,0,0,0.06)}
  body.light-mode .modal{box-shadow:0 20px 60px rgba(0,0,0,0.15)}
  body.light-mode .emp-row:hover{background:rgba(244,185,66,0.08)}
  body.light-mode #loginScreen{background:#F0F0F0}
  body.light-mode .login-box{background:#FFFFFF;box-shadow:0 20px 60px rgba(0,0,0,0.12)}
  body.light-mode .role-btn{background:#F8F8F8}
  body.light-mode .role-btn:hover{background:#F0F0F0}
  body.light-mode .form-input, body.light-mode .form-select{background:#F8F8F8;color:#1A1A1A;border-color:rgba(0,0,0,0.12)}
  body.light-mode .btn-outline{color:#444}
  body.light-mode body::before{opacity:0.3}
  /* TRANSITIONS for theme switch */
  body, header, .card, .stat-card, .tab, .modal, .form-input, .form-select, .emp-row, #loginScreen, .login-box {
    transition: background 0.3S ease, color 0.3S ease, border-color 0.3S ease, box-shadow 0.3S ease;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Tajawal',sans-serif;background:var(--dark);color:var(--text);min-height:100vh;overflow-x:hidden}
  body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
    background:radial-gradient(ellipse at 80% 20%,rgba(244,185,66,0.06) 0%,transparent 50%),
               radial-gradient(ellipse at 20% 80%,rgba(92,158,255,0.04) 0%,transparent 50%)}
  .app{position:relative;z-index:1}
  @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  @keyframes modalIn{from{opacity:0;transform:scale(0.85) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}

  /* HEADER */
  header{background:linear-gradient(135deg,var(--dark2),var(--dark3));border-bottom:1px solid var(--border);padding:13px 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;backdrop-filter:blur(20px)}
  .logo{display:flex;align-items:center;gap:11px}
  .logo-icon{width:38px;height:38px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 0 20px rgba(244,185,66,0.3)}
  .logo-text{font-size:18px;font-weight:800;background:linear-gradient(135deg,var(--gold-light),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .logo-sub{font-size:10px;color:var(--text-muted)}
  .header-right{display:flex;align-items:center;gap:9px}
  .user-chip{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:20px;padding:5px 13px 5px 7px;font-size:12px;font-weight:700}
  .user-chip .dot{width:7px;height:7px;border-radius:50%}
  .is-admin .dot{background:var(--gold);box-shadow:0 0 6px var(--gold)}
  .is-staff .dot{background:var(--blue);box-shadow:0 0 6px var(--blue)}

  /* BUTTONS */
  .btn{padding:8px 17px;border-radius:8px;border:none;cursor:pointer;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;transition:all 0.2S;display:flex;align-items:center;gap:5px}
  .btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--dark);box-shadow:0 4px 14px rgba(244,185,66,0.3)}
  .btn-gold:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(244,185,66,0.4)}
  .btn-outline{background:transparent;border:1px solid var(--border);color:var(--text-muted)}
  .btn-outline:hover{border-color:var(--gold);color:var(--gold)}
  .btn-red{background:rgba(255,92,92,0.1);border:1px solid rgba(255,92,92,0.25);color:var(--red)}
  .btn-red:hover{background:rgba(255,92,92,0.2)}
  .btn-sm{padding:5px 12px;font-size:11px}

  /* ADMIN VISIBILITY */
  .admin-only{display:none}
  body.is-admin .admin-only{display:flex}

  /* TABS */
  .tabs{display:flex;gap:3px;padding:16px 26px 0;border-bottom:1px solid var(--border);background:var(--dark2);overflow-x:auto}
  .tab{padding:10px 20px;border-radius:10px 10px 0 0;border:none;cursor:pointer;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;transition:all 0.2S;background:transparent;color:var(--text-muted);white-space:nowrap}
  .tab.active{background:var(--dark);color:var(--gold);border:1px solid var(--border);border-bottom:1px solid var(--dark)}
  .tab:not(.active):hover{color:var(--text)}

  /* MAIN */
  .main{padding:22px 26px;max-width:1400px;margin:0 auto}
  .section{display:none;opacity:0}
  .section.active{display:block;animation:fadeIn 0.3S ease}

  /* STATS */
  .stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .stat-card{background:var(--dark3);border:1px solid var(--border);border-radius:13px;padding:18px;position:relative;overflow:hidden;transition:transform 0.2S}
  .stat-card:hover{transform:translateY(-3px)}
  .stat-card::before{content:'';position:absolute;top:0;right:0;width:70px;height:70px;border-radius:0 13px 0 70px;opacity:0.08}
  .stat-card.gold::before{background:var(--gold)}.stat-card.green::before{background:var(--green)}.stat-card.blue::before{background:var(--blue)}
  .stat-icon{font-size:24px;margin-bottom:9px}
  .stat-value{font-size:28px;font-weight:900;line-height:1;margin-bottom:3px}
  .stat-card.gold .stat-value{color:var(--gold)}.stat-card.green .stat-value{color:var(--green)}.stat-card.blue .stat-value{color:var(--blue)}
  .stat-label{font-size:11px;color:var(--text-muted);font-weight:500}
  .stat-change{font-size:10px;margin-top:7px;padding:2px 7px;border-radius:20px;display:inline-block;font-weight:700;background:rgba(62,207,142,0.15);color:var(--green)}

  /* CARDS */
  .content-grid{display:grid;grid-template-columns:1fr 350px;gap:16px}
  .card{background:var(--dark3);border:1px solid var(--border);border-radius:13px;overflow:hidden}
  .card-header{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
  .card-title{font-size:14px;font-weight:800;display:flex;align-items:center;gap:7px}
  .badge{padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700}
  .badge-gold{background:rgba(244,185,66,0.15);color:var(--gold)}.badge-green{background:rgba(62,207,142,0.15);color:var(--green)}
  .badge-blue{background:rgba(92,158,255,0.15);color:var(--blue)}.badge-red{background:rgba(255,92,92,0.15);color:var(--red)}
  .badge-purple{background:rgba(167,139,250,0.15);color:var(--purple)}

  /* EMP TABLE */
  .emp-row{display:grid;grid-template-columns:42px 1fr 130px 105px 70px 120px;align-items:center;padding:11px 20px;border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15S;cursor:pointer}
  .emp-row:hover{background:rgba(244,185,66,0.04)}
  .emp-row.hdr{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;cursor:default;padding:8px 20px;border-bottom:1px solid var(--border)}
  .emp-row.hdr:hover{background:none}
  .emp-avatar{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:var(--dark)}
  .emp-name{font-size:13px;font-weight:700}.emp-role{font-size:10px;color:var(--text-muted);margin-top:1px}
  .rank-badge{display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700}
  .rank-1{background:linear-gradient(135deg,rgba(244,185,66,0.2),rgba(201,146,42,0.1));color:var(--gold);border:1px solid rgba(244,185,66,0.3)}
  .rank-2{background:rgba(200,200,200,0.1);color:#C0C0C0;border:1px solid rgba(200,200,200,0.2)}
  .rank-3{background:rgba(205,127,50,0.1);color:#CD7F32;border:1px solid rgba(205,127,50,0.2)}
  .rank-4{background:rgba(92,158,255,0.1);color:var(--blue);border:1px solid rgba(92,158,255,0.2)}
  .rank-5{background:rgba(167,139,250,0.1);color:var(--purple);border:1px solid rgba(167,139,250,0.2)}
  .rank-admin{background:linear-gradient(135deg,rgba(255,215,0,0.25),rgba(255,215,0,0.08));color:#FFD700;border:1px solid rgba(255,215,0,0.4)}
  .pts-bar{width:100%}.pts-val{font-size:11px;font-weight:700;margin-bottom:3px}
  .progress-bar{height:5px;background:rgba(255,255,255,0.07);border-radius:3px;overflow:hidden}
  .progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold-dark),var(--gold-light));transition:width 0.8s ease}
  .row-acts{display:flex;gap:5px;align-items:center}
  .icon-btn{width:27px;height:27px;border-radius:6px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all 0.2s;background:rgba(255,255,255,0.05)}
  .icon-btn:hover{transform:scale(1.1)}
  .icon-btn.edit:hover{background:rgba(92,158,255,0.2)}.icon-btn.del:hover{background:rgba(255,92,92,0.2)}.icon-btn.pts:hover{background:rgba(244,185,66,0.2)}

  /* LEADERBOARD */
  .leaderboard{padding:13px}
  .lb-item{display:flex;align-items:center;gap:9px;padding:9px 11px;border-radius:9px;margin-bottom:6px;transition:background 0.15s;cursor:pointer}
  .lb-item:hover{background:rgba(255,255,255,0.04)}
  .lb-item.first{background:rgba(244,185,66,0.08);border:1px solid rgba(244,185,66,0.2)}
  .lb-rank{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0}
  .r1{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--dark)}.r2{background:rgba(200,200,200,0.15);color:#C0C0C0}.r3{background:rgba(205,127,50,0.15);color:#CD7F32}.rn{background:rgba(255,255,255,0.07);color:var(--text-muted)}
  .lb-av{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:var(--dark)}
  .lb-info{flex:1}.lb-nm{font-size:12px;font-weight:700}.lb-sub{font-size:10px;color:var(--text-muted)}
  .lb-sc{font-size:14px;font-weight:900;color:var(--gold)}

  /* MODALS */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.82);backdrop-filter:blur(8px);z-index:1000;display:none;align-items:center;justify-content:center}
  .modal-overlay.open{display:flex}
  .modal{background:var(--dark3);border:1px solid var(--border);border-radius:17px;width:490px;max-width:95vw;overflow:hidden;animation:modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1)}
  .modal.wide{width:580px}
  .modal-head{padding:18px 20px;background:linear-gradient(135deg,rgba(244,185,66,0.1),rgba(244,185,66,0.03));border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
  .modal-title{font-size:16px;font-weight:800}
  .modal-close{width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,0.07);border:none;color:var(--text-muted);cursor:pointer;font-size:13px;transition:all 0.2s}
  .modal-close:hover{background:rgba(255,92,92,0.15);color:var(--red)}
  .modal-body{padding:20px}
  .modal-footer{padding:13px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}

  /* FORMS */
  .form-group{margin-bottom:14px}
  .form-label{display:block;font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px}
  .form-input,.form-select{width:100%;background:var(--dark4);border:1px solid var(--border);border-radius:8px;padding:9px 13px;color:var(--text);font-family:'Tajawal',sans-serif;font-size:13px;outline:none;transition:border-color 0.2s;direction:rtl}
  .form-input:focus,.form-select:focus{border-color:var(--gold)}
  .form-input::placeholder{color:var(--text-muted)}
  .form-grid2{display:grid;grid-template-columns:1fr 1fr;gap:11px}

  /* POINTS PICKER */
  .pts-picker{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
  .pts-box{background:var(--dark4);border:1px solid var(--border);border-radius:9px;padding:11px;text-align:center;cursor:pointer;transition:all 0.2s}
  .pts-box.selected{border-color:var(--gold);background:rgba(244,185,66,0.1)}
  .pts-box:hover{border-color:rgba(244,185,66,0.4)}
  .pts-box .pv{font-size:18px;font-weight:900;color:var(--gold)}.pts-box .pl{font-size:10px;color:var(--text-muted);margin-top:2px}
  .pts-box.neg .pv{color:var(--red)}
  .pts-custom{display:flex;gap:8px;margin-top:9px;align-items:center}
  .pts-custom span{font-size:11px;color:var(--text-muted);white-space:nowrap}

  /* TICKETS */
  .tickets-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:16px 20px}
  .ticket-card{background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:13px;transition:all 0.2s;position:relative}
  .ticket-card:hover{border-color:rgba(244,185,66,0.3);transform:translateY(-2px)}
  .ticket-id{font-size:10px;color:var(--text-muted);font-weight:700;margin-bottom:4px}
  .ticket-title{font-size:12px;font-weight:700;margin-bottom:7px}
  .ticket-meta{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
  .ticket-status{padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700}
  .status-closed{background:rgba(62,207,142,0.15);color:var(--green)}.status-open{background:rgba(92,158,255,0.15);color:var(--blue)}.status-pending{background:rgba(244,185,66,0.15);color:var(--gold)}
  .ticket-pts{font-size:10px;color:var(--gold);font-weight:700}
  .ticket-assign{font-size:10px;color:var(--text-muted)}
  .ticket-actions-overlay{position:absolute;top:8px;left:8px;display:flex;gap:3px;opacity:0;transition:opacity 0.2s}
  .ticket-card:hover .ticket-actions-overlay{opacity:1}

  /* CRITERIA */
  .criteria-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;padding:16px 20px}
  .criteria-card{background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:15px;position:relative}
  .criteria-icon-big{font-size:24px;margin-bottom:7px}
  .criteria-name{font-size:13px;font-weight:800;margin-bottom:4px}
  .criteria-desc{font-size:10px;color:var(--text-muted);line-height:1.5;margin-bottom:9px}
  .cp-list{display:flex;flex-direction:column;gap:4px}
  .cp-row{display:flex;justify-content:space-between;align-items:center;padding:4px 8px;background:rgba(255,255,255,0.03);border-radius:5px;font-size:10px}
  .cp-pts{font-weight:900;color:var(--gold)}.cp-pts.neg{color:var(--red)}
  .cr-actions{position:absolute;top:9px;left:9px;display:flex;gap:3px;opacity:0;transition:opacity 0.2s}
  .criteria-card:hover .cr-actions{opacity:1}

  /* RANKS */
  .ranks-list{padding:16px 20px}
  .rank-row-item{display:flex;align-items:center;gap:13px;padding:13px 15px;border-radius:11px;margin-bottom:9px;border:1px solid var(--border);background:var(--dark4);transition:all 0.2s;position:relative}
  .rank-row-item:hover{transform:translateX(-4px)}
  .rank-emoji-big{font-size:22px}
  .rank-info-block{flex:1}
  .rank-nm{font-size:14px;font-weight:800}
  .rank-req{font-size:10px;color:var(--text-muted);margin-top:2px}
  .rank-perks{font-size:10px;color:var(--green);margin-top:2px}
  .rank-cnt{font-size:10px;color:var(--text-muted);white-space:nowrap}
  .rank-acts{display:flex;gap:5px;opacity:0;transition:opacity 0.2s}
  .rank-row-item:hover .rank-acts{opacity:1}

  /* LOCK OVERLAY */
  .protected{position:relative}
  .lock-overlay{position:absolute;inset:0;background:rgba(13,13,13,0.75);backdrop-filter:blur(3px);display:flex;align-items:center;justify-content:center;border-radius:13px;z-index:5;flex-direction:column;gap:7px}
  .lock-overlay .lock-icon{font-size:32px}
  .lock-overlay .lock-text{font-size:12px;color:var(--text-muted)}

  /* HISTORY */
  .history-list{padding:0 20px 13px}
  .hist-item{display:flex;align-items:center;gap:9px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
  .hist-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
  .hist-dot.green{background:var(--green);box-shadow:0 0 6px var(--green)}.hist-dot.gold{background:var(--gold);box-shadow:0 0 6px var(--gold)}.hist-dot.red{background:var(--red);box-shadow:0 0 6px var(--red)}
  .hist-text{flex:1;font-size:11px}
  .hist-pts{font-size:11px;font-weight:900}
  .hist-pts.pos{color:var(--green)}.hist-pts.neg{color:var(--red)}
  .hist-time{font-size:10px;color:var(--text-muted)}
  .hist-acts{display:flex;gap:3px;opacity:0;transition:opacity 0.2s}
  .hist-item:hover .hist-acts{opacity:1}

  /* CONFIRM */
  .confirm-modal{background:var(--dark3);border:1px solid rgba(255,92,92,0.3);border-radius:17px;width:360px;max-width:95vw;overflow:hidden;animation:modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1)}
  .confirm-head{padding:18px 20px;border-bottom:1px solid rgba(255,92,92,0.15)}
  .confirm-title{font-size:15px;font-weight:800;color:var(--red)}
  .confirm-body{padding:18px 20px;font-size:13px;color:var(--text-muted);line-height:1.6}
  .confirm-foot{padding:13px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}

  /* DISTRIB */
  .distrib-wrap{padding:13px}

  /* NOTIFY */
  .notif{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(100px);background:var(--dark3);border:1px solid var(--gold);border-radius:11px;padding:12px 20px;display:flex;align-items:center;gap:9px;font-size:13px;font-weight:700;z-index:9999;transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);box-shadow:0 10px 40px rgba(0,0,0,0.5)}
  .notif.show{transform:translateX(-50%) translateY(0)}

  ::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--dark2)}::-webkit-scrollbar-thumb{background:var(--dark5);border-radius:3px}

  @media(max-width:900px){
    .stats-grid{grid-template-columns:1fr 1fr}
    .content-grid{grid-template-columns:1fr}
    .emp-row{grid-template-columns:36px 1fr 100px 90px}
    .emp-row>*:nth-child(n+5){display:none}
    header,.main{padding:10px 12px}
    .tabs{padding:0 12px}
  }

  /* ── LOGIN SCREEN ── */
  #loginScreen{position:fixed;inset:0;background:#0D0D0D;z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0}
  #loginScreen::before{content:'';position:fixed;inset:0;pointer-events:none;
    background:radial-gradient(ellipse at 50% 30%,rgba(244,185,66,0.08) 0%,transparent 60%)}
  .login-box{background:#141414;border:1px solid rgba(244,185,66,0.2);border-radius:20px;padding:40px 36px;width:360px;text-align:center;position:relative;z-index:1;box-shadow:0 20px 60px rgba(0,0,0,0.5)}
  .login-logo{width:72px;height:72px;border-radius:18px;margin:0 auto 16px;overflow:hidden}
  .login-logo img{width:100%;height:100%;object-fit:cover}
  .login-title{font-size:20px;font-weight:900;color:#F4B942;margin-bottom:4px}
  .login-sub{font-size:12px;color:#666;margin-bottom:28px}
